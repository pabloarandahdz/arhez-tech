# 22032026 .gitignore - Arhez Shop
# Protección de archivos de entorno y bases de datos locales

# Dependencias (Frontend / Backend)
node_modules/
dist/
dist-ssr/
*.local

# Archivos de Datos (SQL Local)
saas-app/server/*.db
saas-app/server/*.sqlite
saas-app/server/*.sqlite-journal

# Variables de Entorno (IMPORTANTE)
.env
.env.production
.env.local

# Logs y Debugging
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Sistema Operativo
.DS_Store
Thumbs.db
[Bb]in/
[Oo]bj/

# Misceláneos
.vscode/
.idea/
*.swp
*.bak
